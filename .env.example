# rss-reader configuration — copy to .env and adjust as needed.
# All variables are optional; defaults are shown below.

# SQLite database location
RSS_READER_DB=~/.rss-reader/rss_reader.db

# Port the web app (`rss-reader serve`) listens on
RSS_READER_PORT=8000

# Background auto-refresh (0 to disable)
RSS_READER_AUTO_REFRESH=1

# Auto-refresh interval, seconds
RSS_READER_REFRESH_INTERVAL=900

# Max feeds fetched in parallel per refresh
RSS_READER_CONCURRENCY=8

# Auto-prune read items older than N days (0 = keep all)
RSS_READER_RETENTION_DAYS=0

# Per-feed fetch timeout, seconds
RSS_READER_TIMEOUT=15
